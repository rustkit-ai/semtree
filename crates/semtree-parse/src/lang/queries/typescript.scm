; TypeScript — a superset of the JavaScript shapes plus interfaces/enums/aliases.
(function_declaration       name: (_) @name) @function
(class_declaration          name: (_) @name) @class
(abstract_class_declaration name: (_) @name) @class
(interface_declaration      name: (_) @name) @trait
(type_alias_declaration     name: (_) @name) @struct
(enum_declaration           name: (_) @name) @enum
(method_definition          name: (_) @name) @method
(variable_declarator
  name: (_) @name
  value: [(arrow_function) (function_expression)]) @function
